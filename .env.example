# PostgreSQL connection string
DATABASE_URL=postgresql://<username>:<password>@<host>:5432/<database_name>

# Secret key for JWT authentication
JWT_SECRET=<random_secret>

# Backend port
PORT=8000

# Frontend API URL pointing to the backend
VITE_API_URL=http://localhost:8000

# OpenAI API key for embeddings
OPENAI_API_KEY=<your_openai_api_key>

# Google Generative AI SDK key for answering queries
ANTHROPIC_API_KEY=<your_anthropic_api_key>

# Pinecone API key (if applicable, for vector database alternative)
PINECONE_API_KEY=<your_pinecone_api_key>

# Hugging Face cache directory (mounted volume)
HUGGINGFACE_CACHE_DIR=/root/.cache/huggingface